# Leave unset to use the same-origin "/api" path, which is proxied to the
# staging backend by vite.config.ts (dev) and vercel.json (prod) — this
# avoids the browser making a cross-origin request, since the staging API's
# CORS allowlist doesn't include this app's dev or deployed origin.
# VITE_API_BASE_URL=https://admin-moderator-backend-staging.up.railway.app/api
